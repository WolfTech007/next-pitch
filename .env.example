# Copy to `.env.local` and fill in (never commit `.env.local`).
# Required for production (`npm run start`): at least 16 characters.
SESSION_SECRET=

# Vercel / production: add Redis (Upstash) from Vercel → Storage → Redis, link to this project.
# Vercel usually injects these automatically (names may be KV_* or UPSTASH_REDIS_*).
KV_REST_API_URL=
KV_REST_API_TOKEN=
# If your integration only shows these, they work too:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
